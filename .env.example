# ── API ────────────────────────────────────────────────────────────────────
# Port d'écoute. Render l'impose via la variable PORT — ne pas coder en dur.
PORT=3000

# Origine autorisée pour le CORS (le frontend). En dev : http://localhost:5173
ORIGINE_FRONTEND=http://localhost:5173

# ── Base de données ─────────────────────────────────────────────────────────
# PostgreSQL. En local : une base locale ; sur Render : injectée par la base managée.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emairie?schema=public

# ── Sécurité ────────────────────────────────────────────────────────────────
# Secret de signature des JWT. GÉNÉRER une valeur aléatoire forte en production.
JWT_SECRET=changez-moi-en-production
# Durée de validité d'un jeton d'accès.
JWT_EXPIRATION=2h

# ── OTP ─────────────────────────────────────────────────────────────────────
# Durée de validité d'un code OTP, en minutes.
OTP_DUREE_MINUTES=10
# En dev, on n'envoie pas vraiment de SMS : le code est journalisé dans la console.
# En production, brancher un fournisseur (Twilio, Orange SMS API…) ici.
OTP_MODE=console

# ── Stockage des pièces ─────────────────────────────────────────────────────
# Dossier local où sont écrits les fichiers téléversés.
# NB Render : le disque des services gratuits est éphémère → prévoir un stockage
# objet (S3, R2…) pour la production.
STOCKAGE_DOSSIER=./data/uploads
